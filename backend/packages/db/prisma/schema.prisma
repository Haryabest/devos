// DevOS Prisma schema
// pgvector column is declared as Unsupported — actual index/type are managed by SQL migrations.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────
// Identity
// ─────────────────────────────────────────

enum UserKind {
  GUEST
  USER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String
  avatarUrl     String?
  kind          UserKind @default(USER)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedWorkspaces Workspace[]        @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  refreshTokens   RefreshToken[]
  assignedTasks   Task[]             @relation("TaskAssignee")
  createdTasks    Task[]             @relation("TaskAuthor")
  comments        Comment[]
  auditEvents     AuditEvent[]
  aiConversations AiConversation[]
  notifications   Notification[]

  @@index([kind])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────
// Workspaces / team
// ─────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MANAGER
  DEVELOPER
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User               @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  projects     Project[]
  clients      Client[]
  documents    Document[]
  files        File[]
  integrations Integration[]
  auditEvents  AuditEvent[]
  aiConversations AiConversation[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(DEVELOPER)
  invitedAt   DateTime      @default(now())
  joinedAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────
// Clients
// ─────────────────────────────────────────

model Client {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  email       String?
  phone       String?
  contacts    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([workspaceId])
}

// ─────────────────────────────────────────
// Projects
// ─────────────────────────────────────────

enum ProjectType {
  SAAS
  WEB
  MOBILE
  DESKTOP
  API
  GAME
  OTHER
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  clientId    String?
  name        String
  description String?
  type        ProjectType   @default(OTHER)
  status      ProjectStatus @default(PLANNED)
  startAt     DateTime?
  dueAt       DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId], references: [id])
  tasks     Task[]
  sprints   Sprint[]
  documents Document[]
  files     File[]
  milestones Milestone[]

  @@index([workspaceId, status])
  @@index([clientId])
}

// ─────────────────────────────────────────
// Tasks
// ─────────────────────────────────────────

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  TESTING
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  parentId    String?
  sprintId    String?
  authorId    String
  assigneeId  String?
  title       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  order       Int          @default(0)
  dueAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Task?             @relation("TaskChildren", fields: [parentId], references: [id])
  children     Task[]            @relation("TaskChildren")
  sprint       Sprint?           @relation(fields: [sprintId], references: [id])
  author       User              @relation("TaskAuthor", fields: [authorId], references: [id])
  assignee     User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments     Comment[]
  attachments  File[]
  dependencies TaskDependency[]  @relation("DependencyFrom")
  dependents   TaskDependency[]  @relation("DependencyTo")

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([sprintId])
}

model TaskDependency {
  fromId String
  toId   String

  from Task @relation("DependencyFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Task @relation("DependencyTo", fields: [toId], references: [id], onDelete: Cascade)

  @@id([fromId, toId])
}

model Sprint {
  id        String    @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String
  name      String
  version   String?
  dueAt     DateTime?
  releasedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─────────────────────────────────────────
// Documents / files
// ─────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  folderId    String?
  title       String
  contentMd   String   @default("")
  tags        String[] @default([])
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?          @relation(fields: [projectId], references: [id])
  folder    DocumentFolder?   @relation(fields: [folderId], references: [id])
  revisions DocumentRevision[]

  @@index([workspaceId])
  @@index([projectId])
}

model DocumentFolder {
  id          String   @id @default(cuid())
  workspaceId String
  parentId    String?
  name        String
  createdAt   DateTime @default(now())

  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderTree")
  documents Document[]

  @@index([workspaceId, parentId])
}

model DocumentRevision {
  id         String   @id @default(cuid())
  documentId String
  version    Int
  contentMd  String
  authorId   String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
}

model File {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  taskId      String?
  name        String
  mimeType    String
  size        Int
  storageKey  String   @unique
  checksum    String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id])
  task      Task?     @relation(fields: [taskId], references: [id])

  @@index([workspaceId])
  @@index([projectId])
}

// ─────────────────────────────────────────
// Comments (polymorphic-lite)
// ─────────────────────────────────────────

enum CommentTarget {
  TASK
  DOCUMENT
  PROJECT
}

model Comment {
  id         String        @id @default(cuid())
  targetKind CommentTarget
  targetId   String
  authorId   String
  body       String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  author User  @relation(fields: [authorId], references: [id])
  task   Task? @relation(fields: [targetId], references: [id], map: "Comment_task_fkey")

  @@index([targetKind, targetId])
}

// ─────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────

enum IntegrationProvider {
  GITHUB
  GITLAB
  FIGMA
}

model Integration {
  id            String              @id @default(cuid())
  workspaceId   String
  provider      IntegrationProvider
  externalId    String?
  accessToken   String
  refreshToken  String?
  scopes        String[]            @default([])
  metadata      Json?
  connectedById String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
}

// ─────────────────────────────────────────
// AI
// ─────────────────────────────────────────

enum AiRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AiConversation {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  userId      String
  title       String   @default("New conversation")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  messages  AiMessage[]

  @@index([workspaceId, userId])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           AiRole
  content        String
  sources        Json?
  tokens         Int?
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum EmbeddingSource {
  DOCUMENT
  TASK
  COMMENT
  CODE
  DESIGN
  MESSAGE
}

/// pgvector column `embedding vector(1536)` — see 0001_pgvector migration.
model Embedding {
  id          String          @id @default(cuid())
  workspaceId String
  projectId   String?
  source      EmbeddingSource
  sourceId    String
  chunkIndex  Int             @default(0)
  content     String
  tokens      Int?
  createdAt   DateTime        @default(now())

  embedding Unsupported("vector(1536)")?

  @@unique([source, sourceId, chunkIndex])
  @@index([workspaceId])
  @@index([projectId])
}

model AiMemory {
  id          String   @id @default(cuid())
  workspaceId String
  projectId   String?
  kind        String
  content     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([workspaceId, projectId, kind])
}

// ─────────────────────────────────────────
// Notifications / audit
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  action      String
  target      String?
  targetId    String?
  meta        Json?
  ip          String?
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@index([workspaceId, createdAt])
}
