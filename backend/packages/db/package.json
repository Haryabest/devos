{
  "name": "@devos/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -e .env -- prisma generate",
    "postinstall": "dotenv -e ../../.env -e .env -- prisma generate",
    "migrate": "dotenv -e ../../.env -e .env -- prisma migrate dev --name devos",
    "migrate:deploy": "dotenv -e ../../.env -e .env -- prisma migrate deploy",
    "studio": "dotenv -e ../../.env -e .env -- prisma studio",
    "seed": "dotenv -e ../../.env -e .env -- tsx prisma/seed.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo node_modules/.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1"
  },
  "devDependencies": {
    "@devos/config": "workspace:*",
    "@devos/shared": "workspace:*",
    "argon2": "^0.41.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^5.19.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
