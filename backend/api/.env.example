NODE_ENV=production
PORT=3333
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgresql://devos:devos@postgres:5432/devos
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=change-me-access-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-min-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

CORS_ORIGIN=http://localhost,http://localhost:5173

# AI
AI_PROVIDER=OPENAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Storage: LOCAL | S3 | MINIO | R2 | B2
STORAGE_DRIVER=MINIO
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=devos
S3_ACCESS_KEY=devos
S3_SECRET_KEY=devos12345
S3_FORCE_PATH_STYLE=true

# OAuth integrations
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# Rate limiting (requests per TTL window)
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# Observability (optional)
SENTRY_DSN=

# SMTP email (optional — без SMTP письма логируются worker'ом)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
