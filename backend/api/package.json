    "@fastify/swagger-ui": "^4.1.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.4",
